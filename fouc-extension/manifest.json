{
  "manifest_version": 3,
  "name": "MyManager FOUC Guard",
  "version": "1.0.0",
  "description": "Hides MyManager host UI until the suite theme is ready (prevents flash of unstyled content).",
  "icons": {},
  "content_scripts": [
    {
      "matches": ["*://thefixers.mymanager.gr/*"],
      "exclude_matches": ["*://thefixers.mymanager.gr/*login.php*"],
      "css": ["fouc.css"],
      "js": ["fouc-boot.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}
